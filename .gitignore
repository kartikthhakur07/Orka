# Root .gitignore banao
cat > /Desktop/orka/.gitignore << 'EOF'
# Environment files — KABHI PUSH MAT KARNA!
.env
.env.local
.env.production
.env*.local

# Python
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/.pytest_cache/

# Node
frontend/node_modules/
frontend/.next/
frontend/out/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
EOF